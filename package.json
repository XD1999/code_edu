{
    "name": "ai-debug-explainer",
    "displayName": "AI Debug Explainer",
    "description": "Helps newcomers learn complex projects through AI-powered debugging explanations",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onDebug",
        "onView:ai-debug-explainer.knowledgeMapView",
        "onView:ai-debug-explainer.traceView"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "keybindings": [
            {
                "command": "ai-debug-explainer.explainEncapsulation",
                "key": "ctrl+alt+e",
                "mac": "cmd+alt+e"
            },
            {
                "command": "ai-debug-explainer.explainReduction",
                "key": "ctrl+alt+r",
                "mac": "cmd+alt+r"
            },
            {
                "command": "ai-debug-explainer.explainEncapsulationVisualize",
                "key": "ctrl+shift+e",
                "mac": "cmd+shift+e"
            },
            {
                "command": "ai-debug-explainer.explainReductionVisualize",
                "key": "ctrl+shift+r",
                "mac": "cmd+shift+r"
            },
            {
                "command": "ai-debug-explainer.extractContext",
                "key": "ctrl+alt+s",
                "mac": "cmd+alt+s"
            },
            {
                "command": "ai-debug-explainer.visualizeTerm",
                "key": "ctrl+alt+v",
                "mac": "cmd+alt+v"
            },
            {
                "command": "ai-debug-explainer.diagramTerm",
                "key": "ctrl+shift+v",
                "mac": "cmd+shift+v"
            },
            {
                "command": "ai-debug-explainer.explainConcretizationVisualize",
                "key": "ctrl+shift+c",
                "mac": "cmd+shift+c"
            },
            {
                "command": "ai-debug-explainer.explainConcretization",
                "key": "ctrl+alt+c",
                "mac": "cmd+alt+c"
            },
            {
                "command": "ai-debug-explainer.compare",
                "key": "ctrl+alt+x",
                "mac": "cmd+alt+x"
            },
            {
                "command": "ai-debug-explainer.compareVisualize",
                "key": "ctrl+shift+x",
                "mac": "cmd+shift+x"
            },
            {
                "command": "ai-debug-explainer.explainDeduction",
                "key": "ctrl+alt+d",
                "mac": "cmd+alt+d"
            },
            {
                "command": "ai-debug-explainer.explainDeductionVisualize",
                "key": "ctrl+shift+d",
                "mac": "cmd+shift+d"
            },
            {
                "command": "ai-debug-explainer.toggleLanguageMode",
                "key": "ctrl+alt+f",
                "mac": "cmd+alt+f"
            }
        ],
        "commands": [
            {
                "command": "ai-debug-explainer.toggle",
                "title": "AI Debug Explainer: Toggle"
            },
            {
                "command": "ai-debug-explainer.startLearning",
                "title": "AI Debug Explainer: Start Learning"
            },
            {
                "command": "ai-debug-explainer.stopLearning",
                "title": "AI Debug Explainer: Stop Learning"
            },
            {
                "command": "ai-debug-explainer.viewTrace",
                "title": "AI Debug Explainer: View Trace"
            },
            {
                "command": "ai-debug-explainer.manualCapture",
                "title": "AI Debug Explainer: Manual Capture"
            },
            {
                "command": "ai-debug-explainer.clearTraces",
                "title": "AI Debug Explainer: Clear All Traces"
            },
            {
                "command": "ai-debug-explainer.clearFunctionExplanations",
                "title": "AI Debug Explainer: Clear Function Explanations"
            },
            {
                "command": "ai-debug-explainer.explainEncapsulation",
                "title": "AI Debug Explainer: Encapsulation"
            },
            {
                "command": "ai-debug-explainer.explainReduction",
                "title": "AI Debug Explainer: Reduction"
            },
            {
                "command": "ai-debug-explainer.explainEncapsulationVisualize",
                "title": "AI Debug Explainer: Encapsulation (Auto-Visualize)"
            },
            {
                "command": "ai-debug-explainer.explainReductionVisualize",
                "title": "AI Debug Explainer: Reduction (Auto-Visualize)"
            },
            {
                "command": "ai-debug-explainer.diagramTerm",
                "title": "AI Debug Explainer: Diagram Term"
            },
            {
                "command": "ai-debug-explainer.extractContext",
                "title": "AI Debug Explainer: Extract Context"
            },
            {
                "command": "ai-debug-explainer.visualizeTerm",
                "title": "AI Debug Explainer: Visualize Term"
            },
            {
                "command": "ai-debug-explainer.saveLearningInstance",
                "title": "AI Debug Explainer: Save Learning Instance"
            },
            {
                "command": "ai-debug-explainer.loadLearningInstance",
                "title": "AI Debug Explainer: Load Learning Instance"
            },
            {
                "command": "ai-debug-explainer.deleteLearningInstance",
                "title": "AI Debug Explainer: Delete Learning Instance"
            },
            {
                "command": "ai-debug-explainer.explainConcretization",
                "title": "AI Debug Explainer: Concretization"
            },
            {
                "command": "ai-debug-explainer.explainConcretizationVisualize",
                "title": "AI Debug Explainer: Concretization (Auto-Visualize)"
            },
            {
                "command": "ai-debug-explainer.manageFrameworks",
                "title": "AI Debug Explainer: Manage Saved Frameworks"
            },
            {
                "command": "ai-debug-explainer.compare",
                "title": "AI Debug Explainer: Compare"
            },
            {
                "command": "ai-debug-explainer.compareVisualize",
                "title": "AI Debug Explainer: Compare (Auto-Visualize)"
            },
            {
                "command": "ai-debug-explainer.explainDeduction",
                "title": "AI Debug Explainer: Deduction"
            },
            {
                "command": "ai-debug-explainer.explainDeductionVisualize",
                "title": "AI Debug Explainer: Deduction (Auto-Visualize)"
            },
            {
                "command": "ai-debug-explainer.toggleLanguageMode",
                "title": "AI Debug Explainer: Toggle Language Mode"
            }
        ],
        "configuration": {
            "title": "AI Debug Explainer",
            "properties": {
                "ai-debug-explainer.apiKey": {
                    "type": "string",
                    "description": "API key for the AI service (OpenAI, Moonshot, etc.)"
                },
                "ai-debug-explainer.apiUrl": {
                    "type": "string",
                    "default": "https://api.deepseek.com/chat/completions",
                    "description": "URL for the AI chat completions endpoint"
                },
                "ai-debug-explainer.model": {
                    "type": "string",
                    "default": "deepseek-v4-flash",
                    "description": "AI model to use for explanations"
                },
                "ai-debug-explainer.visualizationApiKey": {
                    "type": "string",
                    "description": "API key for the visualization provider (Anthropic-compatible, e.g. Bailian /apps/anthropic). Leave the key out of the repo; set it in user settings."
                },
                "ai-debug-explainer.visualizationApiUrl": {
                    "type": "string",
                    "default": "https://dashscope.aliyuncs.com/apps/anthropic",
                    "description": "Base URL for the visualization provider's Anthropic Messages-API-compatible endpoint. The /v1/messages path is appended automatically."
                },
                "ai-debug-explainer.visualizationModel": {
                    "type": "string",
                    "default": "glm-5.2",
                    "description": "Model id to use for visualization generation (e.g. glm-5.2 via Bailian)"
                },
                "ai-debug-explainer.appCodePathPatterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "/website/",
                        "website/",
                        "code_edu/website/",
                        ".py"
                    ],
                    "description": "Path substrings that identify application code when capturing debug stack traces. A frame is recorded when its source path contains any of these AND does not contain site-packages/node_modules/<frozen."
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "ai-debug-explainer-view-container",
                    "title": "AI Debug Explainer",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "ai-debug-explainer-view-container": [
                {
                    "type": "webview",
                    "id": "ai-debug-explainer.traceView",
                    "name": "Trace Chat"
                },
                {
                    "type": "webview",
                    "id": "ai-debug-explainer.knowledgeMapView",
                    "name": "Knowledge Map"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/assert": "^1.5.11",
        "@types/mocha": "^10.0.10",
        "@types/node": "16.x",
        "@types/vscode": "^1.74.0",
        "@typescript-eslint/eslint-plugin": "^5.45.0",
        "@typescript-eslint/parser": "^5.45.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.0",
        "eslint": "^8.28.0",
        "typescript": "^4.9.3"
    },
    "dependencies": {
        "axios": "^1.2.1"
    }
}